// AI Skills Assessor — Phase 5 schema (v0.5.0).
//
// Scope additions in this phase:
//   - `SkillEmbedding` removed (replaced by the normalized framework tables below).
//   - `Framework` — master registry of assessment frameworks (SFIA 9, TOGAF, …).
//   - `FrameworkAttributes` — Generic Attributes per level (Autonomy, Influence, …).
//   - `FrameworkSkills` — skill catalog (one row per skill code).
//   - `FrameworkSkillLevels` — level-specific content + pgvector embeddings.
//     The `embedding` column is `Unsupported` because Prisma has no native
//     `vector` type; the RAG adapter queries it via raw SQL.
//
// Phase 2 scope (retained): candidates and assessment sessions, both
// with JSONB `metadata` columns for forward-compatible fields.
// Phase 3 scope (retained): `assessment_reports` scaffold.
//
// See ADR-005 and the Phase 5 implementation doc for the IVFFlat index
// creation SQL (run post-migration as a raw statement).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector(schema: "public")]
}

model Candidate {
  email     String   @id @db.VarChar(255)
  firstName String   @db.VarChar(255)
  lastName  String   @db.VarChar(255)
  // JSONB container for optional / extensible fields:
  //   { "employee_id": "HLX-00481", ... }
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  // Assessment cooldown controls (monitoring phase)
  cooldownOverrideGrantedAt DateTime? @map("cooldown_override_granted_at")
  cooldownOverrideExpiresAt DateTime? @map("cooldown_override_expires_at")
  noRestrictions            Boolean   @default(false) @map("no_restrictions")

  assessmentSessions    AssessmentSession[]
  restrictionAuditLog   CandidateRestrictionAudit[]

  @@index([createdAt])
  @@map("candidates")
}

model AssessmentSession {
  id           String    @id @default(uuid())
  candidateId  String    @db.VarChar(255)
  candidate    Candidate @relation(fields: [candidateId], references: [email], onDelete: Cascade)
  phoneNumber  String    @db.VarChar(32)
  // pending | dialling | in_progress | completed | failed | cancelled | processed
  status       String    @default("pending") @db.VarChar(32)
  // JSONB container for optional / extensible fields:
  //   { "failureReason": "...", "cancelledAt": "...", ... }
  metadata     Json      @default("{}")
  dailyRoomUrl String?
  recordingUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())

  // Monitoring phase: structured termination + error tracking
  terminationReason  String?   @db.VarChar(50)  @map("termination_reason")
  errorDetails       Json?     @map("error_details")
  lastTurnSavedAt    DateTime? @map("last_turn_saved_at")
  focusSuspicious    Boolean   @default(false)  @map("focus_suspicious")
  totalFocusAwayMs   Int       @default(0)      @map("total_focus_away_ms")
  focusEventsJson    Json?     @map("focus_events_json")

  // Phase 6: claim extraction pipeline columns
  candidateName      String?   @db.VarChar(255) @map("candidate_name")
  transcriptJson     Json?     @map("transcript_json")
  claimsJson              Json?     @map("claims_json")
  holisticAssessmentJson  Json?     @map("holistic_assessment_json")
  // Dual review tokens (phase-6-revision-dual-review-tokens)
  expertReviewToken       String?   @unique @db.VarChar(21) @map("expert_review_token")
  supervisorReviewToken   String?   @unique @db.VarChar(21) @map("supervisor_review_token")
  // Expert reviewer audit
  expertSubmittedAt       DateTime? @map("expert_submitted_at")
  expertReviewerName      String?   @db.VarChar(255) @map("expert_reviewer_name")
  expertReviewerEmail     String?   @db.VarChar(255) @map("expert_reviewer_email")
  // Supervisor reviewer audit
  supervisorSubmittedAt   DateTime? @map("supervisor_submitted_at")
  supervisorReviewerName  String?   @db.VarChar(255) @map("supervisor_reviewer_name")
  supervisorReviewerEmail String?   @db.VarChar(255) @map("supervisor_reviewer_email")
  reviewsCompletedAt      DateTime? @map("reviews_completed_at")
  // Deprecated single review token — retained during migration
  reviewToken        String?   @unique @db.VarChar(21) @map("review_token")
  reportStatus       String?   @db.VarChar(30) @map("report_status")
  overallConfidence  Float?    @map("overall_confidence")
  reportGeneratedAt  DateTime? @map("report_generated_at")
  smeReviewedAt      DateTime? @map("sme_reviewed_at")
  expiresAt          DateTime? @map("expires_at")

  assessmentReport AssessmentReport?

  @@index([candidateId])
  @@index([candidateId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@map("assessment_sessions")
}

/// Master framework registry. Each (type, version) tuple is a unique framework.
/// The `rubric` field stores assessor behavioral scoring guidance, cached in the
/// system prompt during assessment initialization.
model Framework {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(50)
  version   String   @db.VarChar(20)
  name      String   @db.VarChar(255)
  rubric    String
  isActive  Boolean  @default(true)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attributes FrameworkAttributes[]
  skills     FrameworkSkills[]

  @@unique([type, version])
  @@index([type])
  @@map("frameworks")
}

/// Generic Attributes (Autonomy, Influence, Complexity, Business Skills, Knowledge)
/// with level-specific descriptors (1-7). One row per (framework, attribute, level).
/// Used to populate the static cached system prompt during assessment initialization.
model FrameworkAttributes {
  id          String    @id @default(uuid())
  frameworkId String
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  attribute   String    @db.VarChar(100)
  level       Int
  description String
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@unique([frameworkId, attribute, level])
  @@index([frameworkId])
  @@map("framework_attributes")
}

/// Skill catalog for a framework. One row per skill (code + name + categories).
/// Separates skill identity from level-specific content and embeddings.
model FrameworkSkills {
  id          String    @id @default(uuid())
  frameworkId String
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  skillCode   String    @db.VarChar(50)
  skillName   String    @db.VarChar(255)
  category    String    @db.VarChar(100)
  subcategory String?   @db.VarChar(100)
  description String
  guidance    String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  levels FrameworkSkillLevels[]

  @@unique([frameworkId, skillCode])
  @@index([frameworkId])
  @@map("framework_skills")
}

/// Level-specific content and embeddings for framework skills.
/// One row per (skill, level) combination.
/// The `embedding` column is Unsupported because Prisma lacks native pgvector support;
/// queries use raw SQL. See the Phase 5 implementation doc for IVFFlat index creation.
model FrameworkSkillLevels {
  id               String          @id @default(uuid())
  frameworkSkillId String
  frameworkSkill   FrameworkSkills @relation(fields: [frameworkSkillId], references: [id], onDelete: Cascade)
  level            Int?
  content          String
  embedding        Unsupported("vector(1536)")?
  metadata         Json            @default("{}")
  createdAt        DateTime        @default(now())

  @@unique([frameworkSkillId, level], name: "idx_unique_skill_level")
  @@index([frameworkSkillId])
  @@map("framework_skill_levels")
}

/// Singleton row holding platform-wide admin configuration.
/// Created on first write; read back with id = 'default'.
model AdminSettings {
  id          String   @id @default("default")
  cooldownDays Int     @default(90)
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.VarChar(255)

  @@map("admin_settings")
}

/// Immutable log of every grant / revoke / toggle action an admin takes
/// on a candidate's assessment restrictions.
model CandidateRestrictionAudit {
  id          String    @id @default(uuid())
  candidateId String    @db.VarChar(255)
  candidate   Candidate @relation(fields: [candidateId], references: [email], onDelete: Cascade)
  // grant_override | revoke_override | set_no_restrictions | unset_no_restrictions
  action      String    @db.VarChar(50)
  grantedBy   String    @db.VarChar(255)
  expiresAt   DateTime?
  reason      String?
  createdAt   DateTime  @default(now())

  @@index([candidateId])
  @@index([createdAt])
  @@map("candidate_restriction_audit")
}

/// Scaffold for SME review reports. Phase 3 creates the table so the
/// deployment has the full schema baseline; Phase 6 (claim extraction
/// pipeline) will add the `claims` FK and richer fields.
model AssessmentReport {
  id            String            @id @default(uuid())
  sessionId     String            @unique
  session       AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reviewToken   String            @unique @db.VarChar(50)
  // generated | sent | in_review | completed
  status        String            @default("generated") @db.VarChar(32)
  metadata      Json              @default("{}")
  generatedAt   DateTime          @default(now())
  smeReviewedAt DateTime?
  expiresAt     DateTime?

  @@index([reviewToken])
  @@index([status])
  @@index([generatedAt])
  @@map("assessment_reports")
}
