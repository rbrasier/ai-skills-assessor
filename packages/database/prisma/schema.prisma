// AI Skills Assessor — Phase 2 schema.
//
// Scope: candidates and assessment sessions, now with JSONB `metadata`
// columns for forward-compatible fields (employee_id, failureReason,
// cancelledAt, …). `candidates.email` is the primary key — per
// phase-2-basic-voice-engine.md §1.9. SFIA-specific tables, claims,
// transcripts, and assessment reports are introduced by later phases
// (claim extraction, RAG knowledge base, SME review portal).

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  email     String   @id @db.VarChar(255)
  firstName String   @db.VarChar(255)
  lastName  String   @db.VarChar(255)
  // JSONB container for optional / extensible fields:
  //   { "employee_id": "HLX-00481", ... }
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  assessmentSessions AssessmentSession[]

  @@index([createdAt])
  @@map("candidates")
}

model AssessmentSession {
  id           String    @id @default(uuid())
  candidateId  String    @db.VarChar(255)
  candidate    Candidate @relation(fields: [candidateId], references: [email], onDelete: Cascade)
  phoneNumber  String    @db.VarChar(32)
  // pending | dialling | in_progress | completed | failed | cancelled
  status       String    @default("pending") @db.VarChar(32)
  // JSONB container for optional / extensible fields:
  //   { "failureReason": "...", "cancelledAt": "...", ... }
  metadata     Json      @default("{}")
  dailyRoomUrl String?
  recordingUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())

  @@index([candidateId])
  @@index([candidateId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@map("assessment_sessions")
}
