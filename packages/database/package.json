{
  "name": "@ai-skills-assessor/database",
  "version": "0.4.0",
  "private": true,
  "description": "Prisma schema, migrations, and generated client for the AI Skills Assessor.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "prisma"],
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "tsx src/seed.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "echo 'no tests' && exit 0",
    "clean": "rm -rf dist .turbo src/generated"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "eslint": "^8.57.1"
  }
}
