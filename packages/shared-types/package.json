{
  "name": "@ai-skills-assessor/shared-types",
  "version": "0.2.0",
  "private": true,
  "description": "Shared TypeScript types used across the monorepo.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "echo 'no tests' && exit 0",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "eslint": "^8.57.1"
  }
}
