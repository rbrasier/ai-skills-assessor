DATABASE_URL=postgresql://user:password@localhost:5432/ai_skills_assessor?schema=public

# ─── How the candidate connects ─────────────────────────────────
# daily   — Pipecat + DailyCo with PSTN dial-out (requires DAILY_* below).
# browser — Self-hosted LiveKit; candidate opens a link in the browser
#           (requires LIVEKIT_* below; DAILY_* are not used).
DIALING_METHOD=daily

# ─── Daily (when DIALING_METHOD=daily) ──────────────────────────
DAILY_API_KEY=
DAILY_DOMAIN=
# Daily SFU region. ap-southeast-1 (Singapore) is co-located with
# Railway Singapore per ADR-006. Use ap-southeast-2 if the voice
# engine is deployed to AWS Sydney.
DAILY_GEO=ap-southeast-1
# Optional Daily phone-number ID to use as outbound caller ID. Leave
# blank to let Daily pick from the workspace pool.
DAILY_CALLER_ID=

# ─── LiveKit self-hosted (when DIALING_METHOD=browser) ───────
# If you use the Docker LiveKit from setup-local.sh (docs/guides/ensure-docker-livekit.sh)
# the server runs with --dev and the default dev key pair:
#   ws://127.0.0.1:7880  /  devkey  /  secret
# Production: use wss:// and your own API keys.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Join page: default is LiveKit’s hosted “custom server” UI; set to your own
# if you self-host a meet / join app.
LIVEKIT_MEET_URL=https://meet.livekit.io/custom
LIVEKIT_TOKEN_TTL_SECONDS=3600

# ─── AI providers (Phase 3 Revision 1) ────────────────────────────
# Missing keys cause the /api/v1/assessment/trigger endpoint to 503
# with a loud log warning; the rest of the service still boots so
# local dev against candidate intake / admin listing remains painless.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall
ELEVENLABS_API_KEY=
# "Rachel" is the ElevenLabs stock voice; override per-tenant in prod.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── STT provider selection (Phase 3 Revision 3) ──────────────────
# deepgram — Deepgram cloud API (default; requires DEEPGRAM_API_KEY above).
# whisper  — Self-hosted faster-whisper via WebSocket (requires WHISPER_STT_URL).
#            Falls back to deepgram if the URL is unset or the service is
#            unreachable when the pipeline starts.
STT_PROVIDER=deepgram
# WebSocket URL of your self-hosted Whisper STT service.
# Local docker compose (--profile stt):  ws://localhost:8001/ws/transcribe
# Railway deployment:                    wss://your-whisper-stt.up.railway.app/ws/transcribe
WHISPER_STT_URL=

# ─── TTS provider selection (Phase 3 Revision 3) ──────────────────
# elevenlabs — ElevenLabs cloud API (default; requires ELEVENLABS_API_KEY above).
# kokoro     — Self-hosted Kokoro-FastAPI via HTTP (requires KOKORO_TTS_URL).
#              Falls back to elevenlabs if the URL is unset or unreachable.
TTS_PROVIDER=elevenlabs
# Base HTTP URL of your self-hosted Kokoro TTS service.
# Local docker compose (--profile tts):  http://localhost:8880
# Railway deployment:                    https://your-kokoro-tts.up.railway.app
KOKORO_TTS_URL=
# Kokoro voice identifier. See Kokoro docs for available voices.
KOKORO_VOICE=af_bella
# PCM sample rate for Kokoro audio output (matches ElevenLabs' 24 kHz default).
KOKORO_SAMPLE_RATE=24000

# ─── Bot identity ─────────────────────────────────────────────────
BOT_NAME=Noa
BOT_ORG_NAME=Resonant

# ─── Runtime ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000

# Set to 1 to use the in-memory persistence adapter instead of Postgres.
# Useful for local development without a running DB (also used by tests).
USE_IN_MEMORY_ADAPTERS=0
