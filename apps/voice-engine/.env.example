DATABASE_URL=postgresql://user:password@localhost:5432/ai_skills_assessor?schema=public
DAILY_API_KEY=
DAILY_DOMAIN=
# Daily SFU region. ap-southeast-1 (Singapore) is co-located with
# Railway Singapore per ADR-006. Use ap-southeast-2 if the voice
# engine is deployed to AWS Sydney.
DAILY_GEO=ap-southeast-1
ANTHROPIC_API_KEY=
LOG_LEVEL=INFO
PORT=8000

# Set to 1 to use the in-memory persistence adapter instead of Postgres.
# Useful for local development without a running DB (also used by tests).
USE_IN_MEMORY_ADAPTERS=0
