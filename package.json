{
  "name": "ai-skills-assessor",
  "version": "0.2.0",
  "private": true,
  "description": "Voice-AI SFIA Skills Assessment Platform — monorepo root.",
  "license": "SEE LICENSE FILE",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
